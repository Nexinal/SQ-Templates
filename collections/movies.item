<h2>Love this movie</h2>

{.section item}

  <!--WRAPPER-->

  <article id="post-{id}" class="movie {@|item-classes}" data-item-id="{id}">

    <!--POST TILE-->

    <h1 class="title" data-content-field="title">
      {.passthrough?}
        <a href="{sourceUrl}" target="_blank">{title}</a>
      {.or}
        <a href="{fullUrl}">{title}</a>
      {.end}
    </h1>

    <p class="meta author">{author}</p>

    <!--MAIN CONTENT-->
    <img src="{assetUrl}" 
        style="object-position: {mediaFocalPoint.x|multiply:100}% {mediaFocalPoint.y|multiply:100}%;height:2rem;width:2rem;" 
    />



    {body}

  </article>

{.end}